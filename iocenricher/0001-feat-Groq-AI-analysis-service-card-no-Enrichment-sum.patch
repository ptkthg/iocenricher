-      model: 'gpt-4o-mini',
+      model: 'llama-3.3-70b-versatile',
       messages: [
-        { role: 'system', content: 'Você é um analista Blue Team. Responda apenas com JSON válido.' },
+        { role: 'system', content: 'Você é um analista sênior de Blue Team. Responda apenas com JSON válido, sem markdown.' },
         { role: 'user', content: prompt }
       ],
-      temperature: 0.3,
-      response_format: { type: 'json_object' }
+      temperature: 0.2,
+      max_tokens: 1024,
     },
     {
       headers: {
-        'Authorization': `Bearer ${process.env.OPENAI_API_KEY}`,
+        'Authorization': `Bearer ${process.env.GROQ_API_KEY}`,
         'Content-Type': 'application/json'
-      }
+      },
+      timeout: 20000
     }
   );
 
-  const content = data.choices[0]?.message?.content;
+  const content = data.choices[0]?.message?.content?.trim();
   try {
-    return JSON.parse(content);
+    // Strip accidental markdown fences if model adds them
+    const clean = content.replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/i, '');
+    return JSON.parse(clean);
   } catch {
-    return { summary: content, context: null, next_steps: [], related_techniques: [] };
+    return {
+      summary: content,
+      threat_actor_profile: null,
+      context: null,
+      next_steps: [],
+      false_positive_likelihood: 'MEDIUM',
+      false_positive_reason: null
+    };
   }
 }
 
